# Painel do Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Token que você escolhe e configura também no webhook da Kiwify
# (Apps → Webhooks), como query string: ...kiwify?token=SEU_TOKEN
KIWIFY_WEBHOOK_TOKEN=

# Opcional: só necessário se o cabeçalho "host" não refletir a URL
# pública (ex.: atrás de alguns proxies). Em localhost pode deixar vazio.
NEXT_PUBLIC_SITE_URL=
